{
  "name": "paycheck-calculator",
  "version": "1.0.3",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac dmg zip --publish never",
    "dist:win": "electron-builder --win nsis --publish never"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongodb": "^6.3.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "electron": "^29.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.paycheckcalculator.app",
    "productName": "Paycheck Calculator",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "server.js",
      "index.html",
      "package.json",
      "images/icon.png",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!dist/**/*"
    ],
    "asarUnpack": [
      "node_modules/mongodb/**/*",
      "node_modules/bson/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "icon": "images/icon.png",
      "notarize": false,
      "artifactName": "Paycheck-Calculator-${version}-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "Paycheck-Calculator-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "images/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Paycheck Calculator",
      "artifactName": "Paycheck-Calculator-Setup-${version}-${arch}.${ext}"
    }
  }
}
